int strStr(char* haystack, char* needle) {
    int hayLen = strlen(haystack);
    int ndlLen = strlen(needle);

    if(ndlLen == 0)
        return 0;

    for(int i = 0; i <= hayLen - ndlLen; i++){
        int j = 0;
        while(j < ndlLen && haystack[i + j] == needle[j]){
            j++;
        }
        if(j == ndlLen)
            return i;
    }
    return -1;
}
