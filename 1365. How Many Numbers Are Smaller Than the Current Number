int* smallerNumbersThanCurrent(int* nums, int numsSize, int* returnSize) {
    int* ans = malloc(sizeof(int) * numsSize);
    
    for(int i = 0; i < numsSize; i++){
        ans[i] = 0;
        for(int j = 0; j < numsSize; j++){
            if(nums[j] < nums[i])
                ans[i]++;
        }
    }
    *returnSize = numsSize;

    return ans;
}

