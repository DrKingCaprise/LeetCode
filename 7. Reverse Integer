#include <limits.h>
int reverse(int x){
    int reversed = 0;
    
    while(x != 0){
        int number = x % 10;

        if (reversed > INT_MAX / 10 || reversed == INT_MAX / 10 && number > 7)
            return 0;
        if (reversed < INT_MIN / 10 || reversed == INT_MIN / 10 && number < -8)
            return 0;

        reversed = reversed * 10 + number;
        x /= 10;
    }
    if(reversed > INT_MAX || reversed < INT_MIN)
        return 0;
    return reversed;
}

