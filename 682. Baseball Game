int calPoints(char** operations, int operationsSize) {
    int* record = malloc(sizeof(int) * operationsSize);
    int x = 0;
    int sum = 0;

    for(int i = 0; i < operationsSize; i++){
        char* input = operations[i];
        if(input[0] == '+'){
            record[x] = record[x - 1] + record[x - 2];
            x++;
        }
        else if(input[0] == 'D'){
            record[x] = record[x - 1] * 2;
            x++;
        }
        else if(input[0] == 'C')
            x--;
        else{
            record[x] = atoi(operations[i]);
            x++;
        }
    }
    for(int i = 0; i < x; i++)
        sum += record[i];
    return sum;
}
