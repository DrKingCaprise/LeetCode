bool canMakeArithmeticProgression(int* arr, int arrSize) {

    int compare(const void* a, const void* b) {
        return (*(int*)a - *(int*)b);
    }

    qsort(arr, arrSize, sizeof(int), compare); // Using Built-in qsort function to sort array in-place
    int Rule = arr[1] - arr[0]; // Establishing a rule to check the next element

    for(int i = 1; i < arrSize; i++){
        if(arr[i] - arr[i-1] != Rule) // If rule is violated, Arithmetic Progression is false
            return false;
    }
    return true;
}
