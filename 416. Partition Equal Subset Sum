bool canPartition(int* nums, int numsSize) {
    int target = 0;

    for(int i = 0; i < numsSize; i++)
        target += nums[i];

    if(target % 2 != 0 || numsSize < 2)
        return false;
    
    target /= 2;

    int sumsSize = target + 1;
    bool sums[sumsSize];
    sums[0] = true;
    
    for(int i = 1; i < sumsSize; i++)
        sums[i] = false;
    
    for(int i = 0; i < numsSize; i++){
        int digit = nums[i];

        for(int j = target; j >= digit; j--){
            if(sums[j - digit])
                sums[j] = true;
        }
    }
    return sums[target];
}
