int* findErrorNums(int* nums, int numsSize, int* returnSize) {
    int dup = 0;
    int pair = 0;
    int next = 0;
    int* ans = malloc(sizeof(int) * 2);
    
    for(int i = 0; i < numsSize; i++){  // Yes, keeping track by flipping the sign of visited elements
        next = abs(nums[i]);
        if(nums[next - 1] < 0)
            dup = nums[i];
        else
            nums[next - 1] = nums[next - 1] * -1;
    }

    for(int i = 0; i < numsSize; i++){
        if(nums[i] > 0){
            pair = i + 1;
            break;
        }
    }
    *returnSize = 2;
    ans[0] = abs(dup);
    ans[1] = abs(pair);

    return ans;
}
