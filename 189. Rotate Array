void reverseArray(int* nums, int left, int right){
    while(left < right){
        int temp = nums[left];
        nums[left] = nums[right];
        nums[right] = temp;
        left++;
        right--;
    }
}

void rotate(int* nums, int numsSize, int k) {
    if(numsSize <= 1 || k == 0)
        return;
    
    k %= numsSize;

    reverseArray(nums, 0, numsSize - 1);
    reverseArray(nums, 0, k - 1);
    reverseArray(nums, k, numsSize - 1);

    return;
}
