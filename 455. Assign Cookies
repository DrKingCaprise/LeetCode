int findContentChildren(int* g, int gSize, int* s, int sSize) {

    int compare(const void* a, const void* b) {
        return (*(int*)a - *(int*)b);
    }

    qsort(g, gSize, sizeof(int), compare);
    qsort(s, sSize, sizeof(int), compare);

    int count = 0;
    int child = 0;
    int cookie = 0;

    while(child < gSize && cookie < sSize){
        if(s[cookie] >= g[child]){
            count++;
            child++;
            cookie++;
        }
        else
            cookie++;
    }

    return count;
}
