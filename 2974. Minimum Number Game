int compare(const void* a, const void* b) {
    return (*(int*)a - *(int*)b);
}

int* numberGame(int* nums, int numsSize, int* returnSize) {
    int* arr = malloc(numsSize * sizeof(int));
    int add = 0;
    *returnSize = numsSize;

    qsort(nums, numsSize, sizeof(int), compare);

    for(int i = 0; i < numsSize - 1; i += 2){
        arr[add++] = nums[i + 1];
        arr[add++] = nums[i];
    }
    return arr;
}

