int* findWordsContaining(char** words, int wordsSize, char x, int* returnSize) {
    
    int* FindX = malloc(wordsSize * sizeof(int)); // Assuming Caller calls free()
    int  Matches = 0;
    char* CurStr;

    for (int i = 0; i < wordsSize; i++){
        CurStr = words[i];
        while(*CurStr){
            if(*CurStr == x){
                FindX[Matches] = i;
                Matches += 1;
                break;
            }
            CurStr++;
        }
    }
    *returnSize = Matches;
    return FindX;
}
