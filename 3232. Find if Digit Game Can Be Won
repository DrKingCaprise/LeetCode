bool canAliceWin(int* nums, int numsSize) {
    int singles = 0;
    int doubles = 0;
    for(int i = 0; i < numsSize; i++){
        if(nums[i] < 10)
            singles += nums[i];
        else
            doubles += nums[i]; 
    }
    if(singles == doubles)
        return false;
    return true;
}
