// Yes, it would be far easier to simply keep track of the number of signed integers,
// but I tried to adhere as closely to the instructions as possible without running into an overflow every other testcase tyvm.

int signFunc(int x){

    if (x > 0)
        return 1;
    else if (x < 0)
        return -1;
    else
        return 0;
}

int arraySign(int* nums, int numsSize) {

    int product = *nums;

    for(int i = 1; i < numsSize; i++){
        if(nums[i] < 0)
            product *= -1;
        else if(nums[i] > 0)
            product *= 1;
        else
            return signFunc(0);
    }
    return signFunc(product);
}
