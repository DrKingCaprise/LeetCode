int mostWordsFound(char** sentences, int sentencesSize) {
    
    int words = 0;
    int max = 0;

    for(int i = 0; i < sentencesSize; i++){
        words = 0;
        for(int j = 0; sentences[i][j] != '\0'; j++){
            if(sentences[i][j] == ' ')
                words++;
        }
        if(words > max)
            max = words;
    }
    return max + 1;
}
